
<Window x:Class="OrderSystem.UI.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Order System" Height="500" Width="400">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Customer"/>
            <TextBox x:Name="txtCustomer" Margin="0,0,0,5"/>
            <TextBlock Text="Product"/>
            <TextBox x:Name="txtProduct" Margin="0,0,0,5"/>
            <TextBlock Text="Price"/>
            <TextBox x:Name="txtPrice" Margin="0,0,0,5"/>
            <TextBlock Text="Quantity"/>
            <TextBox x:Name="txtQty" Margin="0,0,0,5"/>
            <Button Content="Add Item" Click="AddItem_Click"/>
            <Button Content="Create Order" Click="CreateOrder_Click"/>
            <ListBox x:Name="lstOrders"/>
        </StackPanel>
    </Grid>
</Window>
